{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudeTerminal",
  "version": "1.20.1",
  "identifier": "com.claudeterminal.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ClaudeTerminal",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost https://github.com https://ct-analytics.claude-terminal.workers.dev"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "copyright": "Copyright 2024 ClaudeTerminal",
    "shortDescription": "Multi-Instance Claude Code Terminal Manager",
    "longDescription": "ClaudeTerminal is a modern desktop application for managing multiple Claude Code terminal instances. Features include multi-terminal management, configuration profiles, command hints, and a beautiful glassmorphic interface.",
    "category": "DeveloperTool",
    "publisher": "ClaudeTerminal",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.png",
        "sidebarImage": "icons/icon.png",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "compression": "lzma"
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "d8f3b5a2-1c4e-4a9f-b7d6-3e8c2f1a0b9d"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3OUNBMEQ5MzI2RUYwNTgKUldSWThHNHkyYUNjeDAxWjV3WjBnZHVtQlpDKzFtMVFkNmVIbnJuQ3QzbVk4dHI2Sk84ZnB1MjcK",
      "endpoints": [
        "https://github.com/talayash/claude-terminal/releases/latest/download/latest.json",
        "https://ct-analytics.claude-terminal.workers.dev/update"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
